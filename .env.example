DEBUG=True
SECRET_KEY=your-secret-key-change-this

# SQLite — zero-install, just works (default if DATABASE_URL is not set)
# DATABASE_URL=sqlite:///db.sqlite3

# Local MySQL — uncomment and set your password to use MySQL
# DATABASE_URL=mysql://root:YOUR_MYSQL_PASSWORD@127.0.0.1:3306/campusease

# Docker (use this instead when running via docker compose)
# DATABASE_URL=mysql://root:campusease@db:3306/campusease

GEMINI_API_KEY=your-gemini-api-key-optional
